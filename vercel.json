{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/SmartCity/smartcity/dist/index.v2.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/SafeQuest/safety_game/safequest/dist/index.html",
      "destination": "/SafeQuest/safety_game/safequest/dist/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/help",
      "destination": "/help.html"
    },
    {
      "source": "/facts",
      "destination": "/facts.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/smartcity",
      "destination": "/SmartCity/smartcity/dist/index.v2.html"
    },
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ]
}