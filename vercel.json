{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/faq",   "destination": "/faq.html" },
    { "source": "/help",  "destination": "/help.html" },
    { "source": "/facts", "destination": "/facts.html" },
    { "source": "/about", "destination": "/about.html" },

    { "source": "/SafeQuest/safety_game/safequest/dist",
      "destination": "/SafeQuest/safety_game/safequest/dist/index.html" },

    { "source": "/SafeQuest/safety_game/safequest/dist/:path((?!assets/).*)",
      "destination": "/SafeQuest/safety_game/safequest/dist/index.html" },

    { "source": "/:path*", "destination": "/:path*" }
  ]
}
