{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/SafeQuest/safety_game/safequest/dist/index.html",
      "destination": "/SafeQuest/safety_game/safequest/dist/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/faq",   "destination": "/faq.html" },
    { "source": "/help",  "destination": "/help.html" },
    { "source": "/facts", "destination": "/facts.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/:path*", "destination": "/:path*" }
  ]
}
